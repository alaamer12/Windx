{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK",
        "buildCommand": "bun run build",
        "watchPatterns": [
            "frontend/**"
        ]
    },
    "deploy": {
        "startCommand": "bun run preview --host 0.0.0.0 --port $PORT",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
    }
}